def make_message(label):

    messages = {
        "siren": "사이렌 또는 경고음이 감지되었습니다.",
        "car_horn": "자동차 경적 소리가 감지되었습니다.",
        "dog_bark": "강아지 짖는 소리가 감지되었습니다.",
        "knock": "문을 두드리는 소리가 감지되었습니다.",
        "background": "특별한 생활 소리가 감지되지 않았습니다."
    }

    return messages.get(label, "알 수 없는 소리가 감지되었습니다.")


# -----------------------------
# 2. 위험도 판단
# -----------------------------

def get_danger_level(label):

    if label in ["siren", "car_horn"]:
        return "danger"

    elif label in ["dog_bark", "knock"]:
        return "warning"

    else:
        return "normal"
