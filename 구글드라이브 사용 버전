        "import os\n",
        "import numpy as np\n",
        "\n",
        "BASE_DIR = \"/content/drive/MyDrive/OSSP_Project/dataset\"\n",
        "\n",
        "DATA_DIR = os.path.join(BASE_DIR,\"data\")\n",
        "MODEL_DIR = os.path.join(BASE_DIR,\"model\")\n",
        "\n",
        "os.makedirs(DATA_DIR,exist_ok=True)\n",
        "os.makedirs(MODEL_DIR,exist_ok=True)\n",
        "\n",
        "CLASS_NAMES = [\n",
        "    \"0_indoor_alarms\",\n",
        "    \"1_outdoor_warnings\",\n",
        "    \"2_emergency_alarms\"\n",
        "]\n",
        "\n",
        "SAMPLE_RATE = 22050\n",
        "DURATION = 3\n",
        "N_MELS = 64\n",
        "MAX_LEN = 64"
      ],
      "metadata": {
        "id": "wIfGEpaQuRin"
      },
      "execution_count": 39,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "import librosa\n",
        "\n",
        "def extract_mel(file_path):\n",
        "\n",
        "    y, sr = librosa.load(\n",
        "        file_path,\n",
        "        sr=SAMPLE_RATE,\n",
        "        mono=True\n",
        "    )\n",
        "\n",
        "    target_length = SAMPLE_RATE * DURATION\n",
        "\n",
        "    if len(y) < target_length:\n",
        "        y = np.pad(y,(0,target_length-len(y)))\n",
        "    else:\n",
        "        y = y[:target_length]\n",
        "\n",
        "    mel = librosa.feature.melspectrogram(\n",
        "        y=y,\n",
        "        sr=SAMPLE_RATE,\n",
        "        n_mels=N_MELS\n",
        "    )\n",
        "\n",
        "    mel_db = librosa.power_to_db(\n",
        "        mel,\n",
        "        ref=np.max\n",
        "    )\n",
        "\n",
        "    if mel_db.shape[1] < MAX_LEN:\n",
        "\n",
        "        mel_db = np.pad(\n",
        "            mel_db,\n",
        "            (\n",
        "                (0,0),\n",
        "                (0,MAX_LEN-mel_db.shape[1])\n",
        "            )\n",
        "        )\n",
        "\n",
        "    else:\n",
        "        mel_db = mel_db[:,:MAX_LEN]\n",
        "\n",
        "    mel_db = (\n",
        "        mel_db - mel_db.min()\n",
        "    ) / (\n",
        "        mel_db.max() - mel_db.min() + 1e-6\n",
        "    )\n",
        "\n",
        "    mel_db = mel_db[...,np.newaxis]\n",
        "\n",
        "    return mel_db"
      ],
      "metadata": {
        "id": "lufYkpRCuXUP"
      },
      "execution_count": 40,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "from pathlib import Path\n",
        "\n",
        "X=[]\n",
        "y=[]\n",
        "\n",
        "for class_idx,label in enumerate(CLASS_NAMES):\n",
        "\n",
        "    folder = os.path.join(\n",
        "        BASE_DIR,\n",
        "        label\n",
        "    )\n",
        "\n",
        "    files = list(Path(folder).glob(\"*\"))\n",
        "\n",
        "    print(label,len(files))\n",
        "\n",
        "    for file_path in files:\n",
        "\n",
        "        try:\n",
        "\n",
        "            mel = extract_mel(\n",
        "                str(file_path)\n",
        "            )\n",
        "\n",
        "            X.append(mel)\n",
        "            y.append(class_idx)\n",
        "\n",
        "        except Exception as e:\n",
        "\n",
        "            print(\n",
        "                \"실패:\",\n",
        "                file_path,\n",
        "                e\n",
        "            )\n",
        "\n",
        "X=np.array(X)\n",
        "y=np.array(y)\n",
        "\n",
        "print(X.shape)\n",
        "print(y.shape)\n",
        "\n",
        "np.save(\n",
        "    os.path.join(DATA_DIR,\"X.npy\"),\n",
        "    X\n",
        ")\n",
        "\n",
        "np.save(\n",
        "    os.path.join(DATA_DIR,\"y.npy\"),\n",
        "    y\n",
        ")"
      ],
